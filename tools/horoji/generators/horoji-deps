#!/usr/bin/env python3
"""horoji-deps — Dependency generator for Horoji (TASK_02).

Computes import-level dependency relationships for each Horoji subsystem
from Python source files and writes deterministic YAML artifacts to
.project_memory/derived/dependencies/.

Usage:
    horoji-deps [--subsystem SUBSYSTEM]

If --subsystem is omitted, all subsystems declared in the architecture
manifest are processed.

Exit codes:
    0  Success
    1  Failure (structured error written to stderr)
"""

import argparse
import ast
import copy
import datetime
import json
import os
import subprocess
import sys

import yaml

# ---------------------------------------------------------------------------
# Path constants
# ---------------------------------------------------------------------------

REPO_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
MEMORY_ROOT = os.path.join(REPO_ROOT, ".project_memory")
DERIVED_DEPENDENCIES = os.path.join(MEMORY_ROOT, "derived", "dependencies")
CONFIG_FILE = os.path.join(MEMORY_ROOT, "config", "horoji.config.yaml")
MANIFEST_FILE = os.path.join(
    MEMORY_ROOT, "authoritative", "architecture_manifest", "manifest.yaml"
)
SCHEMA_FILE = os.path.join(MEMORY_ROOT, "schemas", "dependency.schema.json")

GENERATOR_NAME = "horoji-deps"
GENERATED_AT_ENV = "HOROJI_GENERATED_AT"

# Canonical directory-to-subsystem mapping.
SUBSYSTEM_DIRS = {
    "horoji_cli": os.path.join(REPO_ROOT, "tools", "horoji", "cli"),
    "horoji_generators": os.path.join(REPO_ROOT, "tools", "horoji", "generators"),
    "horoji_validators": os.path.join(REPO_ROOT, "tools", "horoji", "validators"),
    "horoji_invalidation": os.path.join(REPO_ROOT, "tools", "horoji", "invalidation"),
    "horoji_memory": os.path.join(REPO_ROOT, ".project_memory"),
}

# Map root module names that are recognisably owned by a Horoji subsystem.
# This is intentionally conservative: only well-known intra-project imports
# are mapped; standard library and third-party imports are captured as-is.
MODULE_TO_SUBSYSTEM: dict[str, str] = {}


# ---------------------------------------------------------------------------
# Failure helper
# ---------------------------------------------------------------------------

def fail(msg: str) -> None:
    print(f"ERROR [{GENERATOR_NAME}]: {msg}", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Input loading
# ---------------------------------------------------------------------------

def get_input_commit() -> str:
    try:
        result = subprocess.run(
            ["git", "-C", REPO_ROOT, "rev-parse", "HEAD"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError as exc:
        fail(f"Failed to determine repository revision: {exc}")


def load_config() -> dict:
    if not os.path.isfile(CONFIG_FILE):
        fail(f"Required config file missing: {CONFIG_FILE}")
    with open(CONFIG_FILE, "r", encoding="utf-8") as fh:
        try:
            data = yaml.safe_load(fh)
        except yaml.YAMLError as exc:
            fail(f"Config file parse error: {exc}")
    if not isinstance(data, dict):
        fail(f"Config file must parse to a mapping: {CONFIG_FILE}")
    return data


def load_manifest() -> dict:
    if not os.path.isfile(MANIFEST_FILE):
        fail(f"Required architecture manifest missing: {MANIFEST_FILE}")
    with open(MANIFEST_FILE, "r", encoding="utf-8") as fh:
        try:
            data = yaml.safe_load(fh)
        except yaml.YAMLError as exc:
            fail(f"Manifest parse error: {exc}")
    if not isinstance(data, dict) or "subsystems" not in data:
        fail(f"Architecture manifest malformed — missing 'subsystems' key: {MANIFEST_FILE}")
    return data


def load_schema() -> dict:
    if not os.path.isfile(SCHEMA_FILE):
        fail(f"Required schema file missing: {SCHEMA_FILE}")
    with open(SCHEMA_FILE, "r", encoding="utf-8") as fh:
        try:
            return json.load(fh)
        except json.JSONDecodeError as exc:
            fail(f"Schema file parse error: {exc}")


# ---------------------------------------------------------------------------
# Source analysis
# ---------------------------------------------------------------------------

def collect_python_files(directory: str) -> list[str]:
    """Return a sorted list of .py file paths under *directory* (recursive)."""
    result = []
    if not os.path.isdir(directory):
        return result
    for root, dirs, files in os.walk(directory):
        dirs.sort()
        for fname in sorted(files):
            if fname.endswith(".py"):
                result.append(os.path.join(root, fname))
    return result


def extract_imports(python_files: list[str]) -> list[str]:
    """
    Parse *python_files* and return a sorted, deduplicated list of top-level
    module names imported by those files.
    """
    modules: set[str] = set()

    for fpath in python_files:
        try:
            with open(fpath, "r", encoding="utf-8") as fh:
                source = fh.read()
            tree = ast.parse(source, filename=fpath)
        except OSError as exc:
            fail(f"Failed to read source file {fpath}: {exc}")
        except SyntaxError as exc:
            fail(f"Syntax error in source file {fpath}: {exc}")

        for node in ast.walk(tree):
            if isinstance(node, ast.Import):
                for alias in node.names:
                    # Record only the top-level module name.
                    modules.add(alias.name.split(".")[0])
            elif isinstance(node, ast.ImportFrom):
                if node.module:
                    modules.add(node.module.split(".")[0])

    return sorted(modules)


def map_imports_to_subsystems(
    imports: list[str], known_subsystems: set[str]
) -> list[str]:
    """
    Map a list of imported module names to Horoji subsystem identifiers where
    possible.  Known subsystem names are checked directly; entries in
    MODULE_TO_SUBSYSTEM are resolved; all others are kept as raw module names.

    Returns a sorted, deduplicated list.
    """
    resolved: set[str] = set()
    for mod in imports:
        if mod in known_subsystems:
            resolved.add(mod)
        elif mod in MODULE_TO_SUBSYSTEM:
            resolved.add(MODULE_TO_SUBSYSTEM[mod])
        else:
            resolved.add(mod)
    return sorted(resolved)


# ---------------------------------------------------------------------------
# Output validation
# ---------------------------------------------------------------------------

def validate_output(artifact: dict, schema: dict) -> list[str]:
    required = schema.get("required", [])
    return [
        f"Missing required field: '{field}'"
        for field in required
        if field not in artifact
    ]


def _logical_normalize(artifact: dict) -> dict:
    normalized = copy.deepcopy(artifact)
    provenance = normalized.get("provenance")
    if isinstance(provenance, dict):
        provenance.pop("input_commit", None)
        provenance.pop("generated_at", None)
    return normalized


def _preserve_existing_provenance(output_file: str, artifact: dict) -> dict:
    if not os.path.isfile(output_file):
        return artifact
    try:
        with open(output_file, "r", encoding="utf-8") as fh:
            existing = yaml.safe_load(fh)
    except Exception:
        return artifact
    if not isinstance(existing, dict):
        return artifact
    if _logical_normalize(existing) != _logical_normalize(artifact):
        return artifact
    existing_provenance = existing.get("provenance")
    new_provenance = artifact.get("provenance")
    if not isinstance(existing_provenance, dict) or not isinstance(new_provenance, dict):
        return artifact
    for field in ("input_commit", "generated_at"):
        value = existing_provenance.get(field)
        if isinstance(value, str) and value:
            new_provenance[field] = value
    return artifact


# ---------------------------------------------------------------------------
# Generation
# ---------------------------------------------------------------------------

def generate_subsystem(
    subsystem: str,
    known_subsystems: set[str],
    input_commit: str,
    generated_at: str,
    schema: dict,
) -> None:
    subsystem_dir = SUBSYSTEM_DIRS.get(subsystem)
    if subsystem_dir is None:
        print(
            f"  [{GENERATOR_NAME}] skipping {subsystem}: no source directory mapping",
            file=sys.stderr,
        )
        return

    python_files = collect_python_files(subsystem_dir)
    raw_imports = extract_imports(python_files)
    depends_on = map_imports_to_subsystems(raw_imports, known_subsystems)

    artifact = {
        "provenance": {
            "artifact_type": "dependency",
            "trust_level": "derived",
            "generator": GENERATOR_NAME,
            "schema_version": "1.0.0",
            "input_commit": input_commit,
            "generated_at": generated_at,
        },
        "subsystem": subsystem,
        "depends_on": depends_on,
    }

    errors = validate_output(artifact, schema)
    if errors:
        fail(f"Output validation failed for subsystem '{subsystem}': {errors}")

    if not os.path.isdir(DERIVED_DEPENDENCIES):
        fail(f"Output directory unavailable: {DERIVED_DEPENDENCIES}")

    output_file = os.path.join(DERIVED_DEPENDENCIES, f"{subsystem}.yaml")
    artifact = _preserve_existing_provenance(output_file, artifact)
    with open(output_file, "w", encoding="utf-8") as fh:
        yaml.dump(
            artifact, fh, default_flow_style=False, sort_keys=True, allow_unicode=True
        )

    print(f"  [{GENERATOR_NAME}] generated: {output_file}")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Generate dependency derived artifacts for Horoji subsystems."
    )
    parser.add_argument(
        "--subsystem",
        metavar="SUBSYSTEM",
        help="Subsystem to process (default: all subsystems in manifest)",
    )
    args = parser.parse_args()

    load_config()
    manifest = load_manifest()
    schema = load_schema()

    if not os.path.isdir(DERIVED_DEPENDENCIES):
        fail(f"Output directory unavailable: {DERIVED_DEPENDENCIES}")

    input_commit = get_input_commit()
    generated_at = os.environ.get(GENERATED_AT_ENV)
    if not generated_at:
        generated_at = datetime.datetime.now(datetime.timezone.utc).strftime(
            "%Y-%m-%dT%H:%M:%SZ"
        )

    subsystems = manifest.get("subsystems", {})
    if not isinstance(subsystems, dict) or not subsystems:
        fail("Architecture manifest declares no subsystems")

    known_subsystems = set(subsystems.keys())

    if args.subsystem is not None:
        if args.subsystem not in subsystems:
            fail(
                f"Unknown subsystem '{args.subsystem}'; "
                f"declared subsystems: {sorted(subsystems)}"
            )
        targets = [args.subsystem]
    else:
        targets = sorted(subsystems)

    for subsystem in targets:
        generate_subsystem(subsystem, known_subsystems, input_commit, generated_at, schema)

    print(f"[{GENERATOR_NAME}] generation complete")


if __name__ == "__main__":
    main()
