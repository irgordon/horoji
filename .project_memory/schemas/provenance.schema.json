{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0.0",
  "title": "Horoji Provenance Schema",
  "description": "Schema for provenance metadata attached to all Horoji artifacts",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "trust_level",
    "generator",
    "input_commit",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this schema"
    },
    "artifact_type": {
      "type": "string",
      "description": "Artifact class identifier (e.g. callgraph, contract)"
    },
    "trust_level": {
      "type": "string",
      "enum": ["authoritative", "derived"],
      "description": "Trust classification of the artifact"
    },
    "generator": {
      "type": "string",
      "description": "Name of the tool that produced this artifact"
    },
    "input_commit": {
      "type": "string",
      "description": "Git commit SHA of the repository state used as input"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of artifact generation"
    }
  }
}
